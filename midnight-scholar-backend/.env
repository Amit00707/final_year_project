# Midnight Scholar Backend — Environment Variables

# Database
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/midnight_scholar

# JWT Auth
JWT_SECRET_KEY=your-ultra-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# AI Engine
OPENAI_API_KEY=sk-your-openai-key-here

# Vector Store (Qdrant)
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=midnight_scholar_docs

# AWS S3 Storage
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET=midnight-scholar-pdfs
AWS_REGION=ap-south-1

# Redis (Celery Broker + Rate Limiter)
REDIS_URL=redis://localhost:6379/0

# App Config
APP_NAME=Midnight Scholar
CORS_ORIGINS=http://localhost:3000
